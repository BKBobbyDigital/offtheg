---
import { CATEGORIES, CATEGORY_LABELS } from '../content.config';

const pathname = Astro.url.pathname;
const isActive = (cat: string) => pathname === `/${cat}` || pathname === `/${cat}/`;
---
<header class="border-b-4 border-ink">
  {/* Top utility bar — civic / nyc.gov style */}
  <div class="bg-ink text-paper text-[11px] uppercase tracking-widest">
    <div class="max-w-6xl mx-auto px-4 py-1.5 flex items-center justify-between font-mono">
      <span>An unofficial field guide · Greenpoint, Brooklyn</span>
      <span class="hidden sm:inline">Est. 2026 · Maintained by locals</span>
    </div>
  </div>

  {/* Wordmark band */}
  <div class="bg-g-lime border-b-4 border-ink">
    <div class="max-w-6xl mx-auto px-4 py-6 flex items-end justify-between gap-6 flex-wrap">
      <a href="/" class="flex items-center gap-4 group">
        {/* G train bullet — pt nudges G down for optical centering vs Helvetica's ascender */}
        <span class="inline-flex items-center justify-center size-14 bg-ink text-g-lime font-bold text-3xl leading-none pt-[2px]"
              style="border-radius:9999px !important">G</span>
        <span class="flex flex-col leading-none">
          <span class="text-ink font-bold text-4xl sm:text-5xl tracking-tight">Off the G</span>
          <span class="text-ink/80 font-mono text-xs uppercase tracking-widest mt-2">Greenpoint Field Guide</span>
        </span>
      </a>
      <p class="text-ink/90 text-sm max-w-xs hidden md:block">
        The spots locals actually go to. No algorithm, no sponsored picks, no fluff.
      </p>
    </div>
  </div>

  {/* Category nav — service-indicator chips */}
  <nav class="bg-paper border-b-2 border-ink" aria-label="Categories">
    <div class="max-w-6xl mx-auto px-4 py-3">
      <ul class="flex flex-wrap gap-2 font-mono uppercase tracking-wider text-xs">
        {CATEGORIES.map((cat) => {
          const active = isActive(cat);
          return (
            <li>
              <a
                href={`/${cat}/`}
                aria-current={active ? 'page' : undefined}
                class:list={[
                  'inline-block border-2 border-ink px-3 py-1.5 transition-colors',
                  active
                    ? 'bg-g-lime text-ink font-bold'
                    : 'bg-paper text-ink hover:bg-g-lime',
                ]}
              >
                {CATEGORY_LABELS[cat]}
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </nav>
</header>
